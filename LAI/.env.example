# =============================================================================
# LAI - Environment Configuration
# Copy to .env and adjust values for your deployment
# =============================================================================

# --- Application ---
ENVIRONMENT=development          # development | staging | production

# --- PostgreSQL + pgvector ---
PGHOST=localhost
PGPORT=5433
PGDATABASE=lai_db
PGUSER=lai_user
PGPASSWORD=CHANGE_ME_IN_PRODUCTION

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=                  # Leave empty for no password
REDIS_DB=0
REDIS_CACHE_TTL=3600             # Embedding cache TTL in seconds

# --- MinIO ---
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=laiadmin
MINIO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
MINIO_USE_SSL=false

# --- Embedding Service ---
EMBEDDING_URL=http://localhost:8003
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSION=4096
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT=30

# --- Reranker Service (TEI) ---
RERANKER_URL=http://localhost:8004
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
RERANKER_TIMEOUT=30
RERANKER_MAX_TEXT_LENGTH=400

# --- LLM Service (Groq API) ---
LLM_URL=https://api.groq.com/openai/v1
LLM_MODEL=qwen-3.6-27b-instruct
GROQ_API_KEY=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_TOP_P=0.95

# --- Retrieval Pipeline ---
RETRIEVAL_DENSE_WEIGHT=0.6
RETRIEVAL_SPARSE_WEIGHT=0.4
RETRIEVAL_RRF_K=60
RETRIEVAL_INITIAL_K=100
RETRIEVAL_FINAL_K=7
RETRIEVAL_MIN_SIMILARITY_THRESHOLD=0.5
RETRIEVAL_MIN_CHUNKS_REQUIRED=2

# --- CRAG (Corrective RAG) ---
CRAG_ENABLED=true
CRAG_MAX_LOOPS=2
CRAG_MIN_RELEVANT_CHUNKS=2
CRAG_GRADING_TEMPERATURE=0.0

# --- Chunking ---
CHUNK_MAX_TOKENS=512
CHUNK_MIN_CHARS=400
CHUNK_OVERLAP_TOKENS=100
CHUNK_MAX_FILE_SIZE_MB=50

# --- Batch Processing ---
BATCH_SIZE=10000
BATCH_CHECKPOINT_INTERVAL=5
BATCH_MAX_CONCURRENT=3

# --- Web Search Fallback (Brave API) ---
BRAVE_ENABLED=false
BRAVE_API_KEY=                   # Get from https://brave.com/search/api/
BRAVE_MAX_RESULTS=5

# --- JWT Authentication ---
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RATE_LIMIT_PER_MINUTE=60
API_MAX_QUERY_LENGTH=2000

# --- Session ---
SESSION_MAX_TURNS=10
SESSION_EXPIRY_DAYS=7

# --- Monitoring SLOs ---
MONITOR_TARGET_REFUSAL_RATE_MIN=0.15
MONITOR_TARGET_REFUSAL_RATE_MAX=0.25
MONITOR_TARGET_CITATION_VERIFICATION_RATE=0.98
MONITOR_TARGET_P95_LATENCY_MS=3000
