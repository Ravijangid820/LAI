{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "LAI chat backend — RAG funnel, validator alarms, lawyer feedback, and HTTP latency. Source metrics live in lai.api.metrics + prometheus-fastapi-instrumentator.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Query rate (per second, by mode)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "ops"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(lai_rag_query_total[5m])) by (mode)",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Query latency — p50 / p95 / p99 (seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(lai_rag_query_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(lai_rag_query_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(lai_rag_query_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "(unbelegt) responses — model fabrication rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Share of /query turns where the citation validator rewrote at least one sentence with the (unbelegt) marker. >5% over a sustained period is the cue to investigate the prompt or retrieval recall.",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.15 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(lai_rag_citation_unbelegt_responses_total[15m])) / clamp_min(sum(rate(lai_rag_query_total[15m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Jurisdiction warnings — wrong-Bundesland citations",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Share of /query turns where check_jurisdiction emitted ≥1 warning (e.g. 10H BayBO cited for a Niedersachsen matter — the lawyer's #2 v0 complaint).",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(lai_rag_jurisdiction_warnings_responses_total[15m])) / clamp_min(sum(rate(lai_rag_query_total[15m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Lawyer feedback verdicts (cumulative)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(lai_feedback_total{rating=\"thumbs_up\"})",
          "legendFormat": "👍 thumbs up",
          "refId": "A"
        },
        {
          "expr": "sum(lai_feedback_total{rating=\"thumbs_down\"})",
          "legendFormat": "👎 thumbs down",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Approval rate (1h rolling)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Share of recent feedback submissions that were thumbs-up. Below 50% means the lawyer is dissatisfied; dig into the (unbelegt) and jurisdiction panels first.",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          }
        }
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(rate(lai_feedback_total{rating=\"thumbs_up\"}[1h])) / clamp_min(sum(rate(lai_feedback_total[1h])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Retrieval depth — chunks returned per query",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Distribution of how many chunks each /query returned (post-dedup, post-rerank, capped at top_k). The leftmost bin is chat-only (0 chunks); the rightmost is power-users asking for top_k=8+.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "options": {
        "calculate": false,
        "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "scheme": "Oranges", "steps": 64 },
        "yAxis": { "axisPlacement": "left", "unit": "short", "decimals": 0 },
        "cellGap": 1,
        "cellValues": { "decimals": 0 }
      },
      "targets": [
        {
          "expr": "sum(rate(lai_rag_retrieval_chunks_returned_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "HTTP requests per route (rate, per second)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "From prometheus-fastapi-instrumentator. Shows demand by endpoint — useful for spotting whether the streaming endpoint is taking over.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"serve_rag\"}[5m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "HTTP latency p95 by route (seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"serve_rag\"}[5m])) by (le, handler))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["lai", "rag", "chat"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LAI — Chat / RAG Backend",
  "uid": "lai-rag-chat",
  "version": 1,
  "weekStart": ""
}
