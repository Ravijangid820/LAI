# LAI v1 — Backend Environment Configuration (sample)
# Copy to .env and fill in DB_PASSWORD before docker compose up.

# ── Database (must match the lai_postgres_main runtime container) ──
DB_NAME=lai_db
DB_USER=lai_user
DB_PASSWORD=CHANGE_ME

# ── Application ──
ENVIRONMENT=development

# ── Networking ──
BACKEND_PORT=18001
BACKEND_BIND_HOST=127.0.0.1

# ── CORS origins (comma-separated) ──
CORS_ORIGINS=http://localhost:5173

# ── External services (LAI runtime container DNS names) ──
LLM_URL=http://lai_analyzer_llm:8000/v1
LLM_MODEL=qwen3.6-27b
EMBEDDING_URL=http://lai_embedding:8000
RERANKER_URL=http://host.docker.internal:8004
