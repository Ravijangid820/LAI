# =============================================================================
# LAI — Auth + Email Environment Template
# =============================================================================
#
# Source plan: harsh/AUTH_PLAN.md §8 (Secrets & deployment)
# Companion: .env.example (DB / Redis / MinIO / LLM stack)
#
# THIS FILE IS A TEMPLATE — copy, fill in, do NOT commit the result.
#
# Dev / local:   copy to  LAI/.env       (gitignored)  and source before launch
# Production:    copy to  /etc/lai/secrets/auth.env  + .../email.env  chmod 600
#                owned by the service user, loaded via systemd EnvironmentFile=
#
# Both serve_rag (port 18000) AND the microservice container (port 18001)
# MUST read the same LAI_AUTH_JWT_ACCESS_SECRET. If the two values diverge,
# tokens issued by serve_rag will be rejected by the microservice and the
# user sees random 401s mid-session.
#
# NEVER put any of these in LAI-UI/.env or anywhere with a VITE_ prefix —
# Vite bundles VITE_* vars into the public JS the browser downloads.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Auth — JWT signing (REQUIRED)
# -----------------------------------------------------------------------------
# Missing or weak (<32 chars) value = serve_rag will fail to start.
# Generate a fresh value with:   openssl rand -base64 48
# Rotation cadence: 90 days. On rotation, in-flight access tokens become
# invalid and clients silently re-issue via the refresh cookie path.
LAI_AUTH_JWT_ACCESS_SECRET=REPLACE_WITH_openssl_rand_base64_48

# Algorithm and issuer are pinned in code; uncomment only if you have a
# deliberate reason to change them.
# LAI_AUTH_JWT_ALGORITHM=HS256
# LAI_AUTH_JWT_ISSUER=lai

# Access-token lifetime, in minutes. Short on purpose — short TTL is the
# revocation strategy (v1 has no per-token revocation list).
# LAI_AUTH_JWT_ACCESS_TTL_MINUTES=15

# Refresh-token lifetimes, in days.
# - jwt_refresh_ttl_days:                   default ("not signed in long-term")
# - jwt_refresh_ttl_days_remember_me:       set when the login checkbox is ticked
# LAI_AUTH_JWT_REFRESH_TTL_DAYS=30
# LAI_AUTH_JWT_REFRESH_TTL_DAYS_REMEMBER_ME=90


# -----------------------------------------------------------------------------
# 2. Auth — refresh cookie attributes
# -----------------------------------------------------------------------------
# Cookie name and path are baked into the auth router; both backends agree.
# LAI_AUTH_REFRESH_COOKIE_NAME=lai_refresh
# LAI_AUTH_REFRESH_COOKIE_PATH=/auth

# Secure cookie. MUST be true in any non-localhost deployment.
# For local plain-http dev only, flip to false (the browser refuses to
# send Secure cookies over http otherwise).
LAI_AUTH_REFRESH_COOKIE_SECURE=true

# SameSite — controls cross-site cookie behavior.
#   lax     → UI and API share an eTLD+1, e.g. both at lai.de
#   none    → UI and API cross-origin, e.g. app.lai.de calling api.lai.de.
#             Requires SECURE=true AND CORS preflight allow-credentials=true.
#   strict  → unusual; blocks the cookie on third-party navigations.
# Decision = AUTH_PLAN Q11.
LAI_AUTH_REFRESH_COOKIE_SAMESITE=lax


# -----------------------------------------------------------------------------
# 3. Auth — password hashing & policy
# -----------------------------------------------------------------------------
# bcrypt rounds. OWASP 2024 floor = 12. Raise to 13/14 for higher
# assurance at the cost of ~2x / 4x login latency. Capped at 15 to
# bound worst-case login wall-clock.
# LAI_AUTH_BCRYPT_ROUNDS=12

# Length policy applied at signup + reset.
# LAI_AUTH_PASSWORD_MIN_LENGTH=12
# LAI_AUTH_PASSWORD_MAX_LENGTH=128

# Password-reset token TTL, in minutes.
# LAI_AUTH_RESET_TOKEN_TTL_MINUTES=30


# =============================================================================
# 4. Brevo — transactional email (OPTIONAL but required for password reset)
# =============================================================================
# AUTH_PLAN §2: v1 uses Brevo for exactly one flow — password reset.
# Without these vars, /auth/forgot-password still writes a reset row to
# password_reset_tokens; you just have to pull the token from the DB or
# from serve_rag's "email.disabled.reset_email" log line. Set
# LAI_EMAIL_ENABLED=true once the Brevo account + domain DNS are ready.

# Master switch. false in dev/CI logs the rendered email instead of
# sending — useful for testing without a Brevo account.
LAI_EMAIL_ENABLED=false

# Brevo API key — generate in Brevo console → SMTP & API → API Keys.
# IMPORTANT: scope it to "Transactional Email Send only", never the
# master key. Rotation cadence: 180 days.
# LAI_EMAIL_BREVO_API_KEY=xkeysib-REPLACE_WITH_YOUR_KEY

# Sender identity. Must be a verified sender in Brevo (DNS SPF + DKIM
# records published for this domain).
# LAI_EMAIL_SENDER_EMAIL=no-reply@yourdomain.com
# LAI_EMAIL_SENDER_NAME=LAI

# Public URL of the LAI UI. Used to build the reset link the user

# clicks:  {public_app_base_url}/reset-password?token=...
# Must be the EXTERNAL URL the browser sees, not an internal Docker
# hostname.
# LAI_EMAIL_PUBLIC_APP_BASE_URL=https://app.yourdomain.com

# Per-request timeout against the Brevo API, in seconds.
# LAI_EMAIL_TIMEOUT_SECONDS=10


# =============================================================================
# 5. CORS (related but lives next to existing CORS_ORIGINS in .env)
# =============================================================================
# AUTH_PLAN §9 step 6 deprecates the wildcard allow_origins=["*"] in
# serve_rag. When that lands, the allow-list will be driven by the
# same CORS_ORIGINS var the microservice already reads.
#
# CORS_ORIGINS=https://app.yourdomain.com,https://staging.yourdomain.com
# When ENVIRONMENT=development, localhost:3000 and localhost:5173 are
# appended automatically by micro-services/api.py.


# =============================================================================
# Frontend env reference (NOT loaded from this file)
# =============================================================================
# The React app needs only ONE auth-related env var, set in a separate
# file (LAI-UI/.env.local — gitignored):
#
#     VITE_API_BASE_URL=http://localhost:18000
#
# Anything VITE_* ends up in the public JS bundle. Do not put any
# Brevo / JWT / DB secrets in LAI-UI/.env*.


# =============================================================================
# Quick checklist before first boot
# =============================================================================
#  [ ] Generated and pasted a real LAI_AUTH_JWT_ACCESS_SECRET (>=32 chars)
#  [ ] LAI_AUTH_REFRESH_COOKIE_SECURE=false ONLY when running on plain http
#  [ ] LAI_EMAIL_ENABLED is intentional (false until Brevo is verified)
#  [ ] This file is in .gitignore — confirm before any commit
#  [ ] Production: file is at /etc/lai/secrets/auth.env, chmod 600, owner=service user
#  [ ] Production: same secret in /etc/lai/secrets/auth.env on the microservice host
#  [ ] systemd unit has  EnvironmentFile=/etc/lai/secrets/auth.env
