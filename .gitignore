# Runtime caches (HuggingFace model downloads, vLLM compile cache, etc.)
LAI/.runtime-cache/
.runtime-cache/

# Raw corpus (671 GB of legal source docs; lives in LAI/data/raw/)
LAI/data/

# Stress-test volume sets: a symlink farm into the (ignored) VDR corpus plus
# manifests that enumerate confidential document names/paths. Regenerable
# locally; the symlinks are absolute paths that break on clone. Never track.
LAI/demo-seed/stress-volumes/

# Eval / audit output artifacts under scripts/ — regenerable, kept local but not tracked.
LAI/scripts/eval/rag_eval_results/
LAI/scripts/eval/_embed_cache/
LAI/scripts/eval/_rewrite_cache/
LAI/scripts/**/*_results.json
LAI/scripts/archive/temp/*_audit.json

# Additional virtualenvs outside LAI/.venv
vllm-env/
*/venv/

# MinIO backups (can be 1TB+ per bucket)
minio-backup/
minio-local/

# Native vLLM server logs
LAI/logs/vllm/

# Pipeline checkpoints and local SQLite DBs
LAI/processed/*.db
LAI/processed/*.db-*
LAI/processed/db_export/
LAI/processed/pipeline_local.db*

# DB-snapshot backups (post-recovery JSONL/NPZ — can be large)
LAI/processed/backups/

# Runtime logs (tmux/background scripts write here)
LAI/logs/tmp/

# The web UI lives in its own repo as of v1.0.0 — see LAI/README.md.
# A clone of it commonly sits at /data/projects/lai/LAI-UI/ for local dev,
# but is its own git repo and must not show up as untracked here.
LAI-UI/

# Micro-services local env (DB credentials, CORS origins, etc.)
LAI/micro-services/.env

# Local backend env (auth secrets, Brevo key, etc.). The .env.example*
# templates are committed; the resolved .env files with real values
# are never. AUTH_PLAN §8.1 puts production secrets at
# /etc/lai/secrets/*.env outside the repo entirely.
LAI/.env
LAI/.env.auth
LAI/.env.local
LAI/.env.*.local

# Top-level scripts folder (personal scripts, not project code)
/scripts/

# Fine-tune JSONL exports and checkpoints (large, reproducible from SQLite)
LAI/training/fine_tuning/data/
LAI/training/fine_tuning/output/
